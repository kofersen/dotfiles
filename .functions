#
# ~/.functions
#

# --- Aliases ---
alias l='lsd -atl'
alias cls='clear && ls'

# --- OZ Gateway ---
_OZ_KEY_REF='pass://oz-vault/ai-gateway-key/password'

opencode() {
  local home_arg=()
  if [ "${1:-}" = "--home" ]; then
    home_arg=(--home)
    shift
  fi

  mkdir -p \
    "$HOME/.config/opencode" \
    "$HOME/.local/share/opencode" \
    "$HOME/.cache/opencode"

  local oz_key
  oz_key="$(pass-cli run \
    --env-file <(echo "OZ_API_KEY=$_OZ_KEY_REF") \
    -- printenv OZ_API_KEY)" || {
      echo "opencode: failed to resolve OZ_API_KEY via pass-cli" >&2
      return 1
    }
  [ -n "$oz_key" ] || {
    echo "opencode: resolved OZ_API_KEY is empty" >&2
    return 1
  }

  OZ_API_KEY="$oz_key" sandbox \
    "${home_arg[@]}" \
    --net \
    --env OZ_API_KEY \
    --bind-extra    "$HOME/.config/opencode"      /tmp/home/.config/opencode \
    --bind-extra    "$HOME/.local/share/opencode" /tmp/home/.local/share/opencode \
    --bind-extra    "$HOME/.cache/opencode"       /tmp/home/.cache/opencode \
    --ro-bind-extra "$HOME/.gitconfig"            /tmp/home/.gitconfig \
    -- opencode "$@"
}

opencode-raw() {
  local bin
  bin="$(which -a opencode | grep -v "^$(type -p opencode 2>/dev/null)\$" \
         | grep -vF "$(declare -F opencode)" | head -1)"
  [ -n "$bin" ] && [ -x "$bin" ] || {
    echo "opencode-raw: no opencode binary on PATH" >&2
    return 1
  }
  pass-cli run --env-file <(echo "OZ_API_KEY=$_OZ_KEY_REF") -- "$bin" "$@"
}
